# Copy this file to .env and fill in the values.
# Never commit .env — it's in .gitignore.

# ── Dashboard ─────────────────────────────────────────────────────────────────
# Password to log into the dashboard UI (optional — leave blank for open access)
DASHBOARD_PASSWORD=

# Shared secret devices send in X-Api-Key header (optional — leave blank for open access)
DASHBOARD_API_KEY=

# Discord webhook URL for stale/error alerts (optional)
DISCORD_WEBHOOK_URL=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get your secret key from https://dashboard.stripe.com/apikeys
# Use sk_test_... for testing, sk_live_... for real payments
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — from https://dashboard.stripe.com/webhooks
# Register https://due-light.com/webhook for the checkout.session.completed event
# Only needed if you want webhook verification (optional for basic testing)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
